# No trailing slash. On Vercel set this in project env and redeploy after changes.
VITE_API_URL=http://localhost:5000

# Same email as server ADMIN_EMAIL (Auth0 account that can open Admin panel)
VITE_ADMIN_EMAIL=you@example.com

# Optional — defaults are in auth0Config.ts if unset
# VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
# VITE_AUTH0_CLIENT_ID=your_client_id
