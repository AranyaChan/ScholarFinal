GEMINI_API_KEY=
PORT=5000
ATLAS_URI=
# Auth0 login email allowed to use /api/admin (must match VITE_ADMIN_EMAIL on client)
ADMIN_EMAIL=you@example.com
# Comma-separated for multiple frontends (production + Vercel previews)
CORS_ORIGIN=http://localhost:5173
# Get key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
# Optional — arXiv prefers a descriptive User-Agent with your contact
# ARXIV_USER_AGENT=ScholarAI/1.0 (mailto:you@email.com)
